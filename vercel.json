{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "^/(.*\\.(png|jpg|jpeg|gif|svg|ico|webp|css|js|woff2?|ttf))$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
